flowchart TD
    A["document_container_agent(source_text)"] --> B["DocumentStructuringPipeline.run(source_text)"]
    B --> C["_orchestrate_document(source_text)"]
    C --> C1["_parse_structured(DOCUMENT_ORCHESTRATOR_PROMPT, ..., model.DocumentOrchestrator)"]
    C1 --> D["model.DocumentOrchestrator"]
    D --> E["for each model.OrchestratorElement in orchestration.elements"]

    E --> F{"_convert_element_to_steps(element)"}

    F -->|type = theorem| G["_extract_theorem(raw_source, header_hint, label_hint)"]
    F -->|type = definition| H["_extract_definition(raw_source, header_hint, label_hint)"]
    F -->|type = section| I["_build_section(element)"]
    F -->|type = figure| J["_extract_figure(raw_source, label_hint)"]
    F -->|type = table| K["_extract_table(raw_source, label_hint)"]
    F -->|"paragraph or remark<br/>content_kind = mathematical_prose"| L["_build_math_paragraph_steps(element)"]
    F -->|"paragraph or remark<br/>content_kind = prose or unset"| M["_build_paragraph(element)"]

    G --> G1["_parse_structured(THEOREM_EXTRACTION_PROMPT, ..., model.Theorem)"]
    G1 --> N{"proof present?"}
    N -->|yes| O["_extract_proof_source(raw_source)"]
    O --> O1["_parse_structured(PROOF_SOURCE_EXTRACTION_PROMPT, ..., ProofSourceExtractionResult)"]
    O1 --> P["_extract_logical_steps(proof_source)"]
    P --> P1["_parse_structured(LOGICAL_STEP_EXTRACTION_PROMPT, ..., LogicalStepExtractionResult)"]
    P1 --> Q["model.LogicalStepSequence"]
    Q --> R["attach theorem.proof = model.ProofDetails(root=proof_steps)"]
    N -->|no| S["return theorem without proof"]
    R --> T["_wrap_step(theorem)"]
    S --> T

    H --> H1["_parse_structured(DEFINITION_EXTRACTION_PROMPT, ..., model.Definition)"]
    H1 --> U["_wrap_step(definition)"]
    I --> V["_wrap_step(section)"]
    J --> J1["_parse_structured(FIGURE_EXTRACTION_PROMPT, ..., model.Figure)"]
    J1 --> W["_wrap_step(figure)"]
    K --> K1["_parse_structured(TABLE_EXTRACTION_PROMPT, ..., model.Table)"]
    K1 --> X["_wrap_step(table)"]
    L --> Y["model.LogicalStepSequence.root<br/>list of model.LogicalStep"]
    M --> Z["_wrap_step(paragraph)"]

    T --> AA["extend body_steps"]
    U --> AA
    V --> AA
    W --> AA
    X --> AA
    Y --> AA
    Z --> AA

    AA --> AB{"more elements?"}
    AB -->|yes| E
    AB -->|no| AC["document = model.Document(body=model.LogicalStepSequence(root=body_steps), title, abstract)"]
    AC --> AD["return model.DocumentContainer(document=document)"]

    classDef entry fill:#e8f1ff,stroke:#2f5ea8,stroke-width:1px;
    classDef loop fill:#eef8e8,stroke:#4d7c0f,stroke-width:1px;
    classDef llm fill:#fff3d6,stroke:#a16207,stroke-width:1px;
    classDef output fill:#f7e8ff,stroke:#7e22ce,stroke-width:1px;

    class A,B entry;
    class E,F,AA,AB loop;
    class C,C1,G,G1,H,H1,J,J1,K,K1,L,O,O1,P,P1 llm;
    class D,Q,AC,AD output;
