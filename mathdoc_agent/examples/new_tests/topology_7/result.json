                            "label": "source.root.theorem.proof.root.reverse.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood_setup.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_U.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_U.arbitrary-neighborhood.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary-U.arbitrary_U.arbitrary_neighborhood",
                            "header": "Claim",
                            "claim": "U\\subseteq X, U is open in X, and L\\in U.",
                            "proof": {
                              "type": "Proof",
                              "proof_steps": [
                                {
