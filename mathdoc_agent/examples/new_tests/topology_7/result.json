                                        },
                                        "id": "source.root.theorem.proof.root.reverse.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood_setup.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary_neighborhood.arbitrary-neighborhood.arbitrary-neighborhood.arbitrary_U.arbitrary_neighborhood.arbitrary_neighborhood.arbitrary_U.arbitrary-neighborhood.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary_U.arbitrary-U.arbitrary_U.arbitrary_neighborhood.arbitrary_U.arbitrary_U.arbitrary-neighborhood",
