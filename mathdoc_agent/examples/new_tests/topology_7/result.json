                      "label": "source.root.theorem.proof.root.reverse.arbitrary_neighborhood.arbitrary_neighborhood",
                      "header": "Claim",
                      "claim": "U is an open subset of X and L∈U.",
                      "proof": {
                        "type": "Proof",
                        "proof_steps": [
