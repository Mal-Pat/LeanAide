              },
              {
                "type": "Theorem",
                "label": "source.root.theorem.proof.root.reverse.eventual_membership",
                "header": "Claim",
                "claim": "For all n≥N, x_n∈U.",
                "proof": {
                  "type": "Proof",
                  "proof_steps": [
                    {
                      "type": "assume_statement",
                      "assumption": "n≥N",
                      "variable_name": "n",
                      "variable_type": "natural number",
                      "statement": "Let n≥N be arbitrary."
                    },
                    {
                      "deduced_from_claim": [
                        "There exists N∈ℕ such that for all n≥N, x_n=L.",
                        "n≥N"
                      ],
                      "type": "assert_statement",
                      "claim": "x_n=L",
                      "proof_method": "By the eventual equality hypothesis applied to n."
                    },
                    {
                      "deduced_from_claim": [
                        "x_n=L",
                        "L∈U"
                      ],
                      "type": "assert_statement",
                      "claim": "x_n∈U",
                      "proof_method": "Since x_n=L and L∈U."
                    },
                    {
                      "deduced_from_claim": [
                        "For arbitrary n≥N, x_n∈U."
                      ],
                      "deduced_from_theorem": [
                        {
                          "claim": "If an element satisfying an arbitrary condition was chosen arbitrarily and a property was proved for it, then the property holds for all elements satisfying that condition.",
                          "name": "Universal generalization",
                          "description": "Used to conclude the statement for all n≥N."
                        }
                      ],
                      "type": "assert_statement",
                      "claim": "For all n≥N, x_n∈U.",
                      "proof_method": "By universal generalization from the arbitrary n≥N."
                    }
                  ]
                },
                "id": "source.root.theorem.proof.root.reverse.eventual_membership",
                "status": "resolved",
                "text": "For all n≥N, x_n=L∈U, so x_n∈U."
              },
              {
                "type": "Theorem",
                "label": "source.root.theorem.proof.root.reverse.convergence_condition",
                "header": "Claim",
                "claim": "There exists M∈ℕ such that for all n≥M, x_n∈U.",
                "proof": {
                  "type": "Proof",
                  "proof_steps": [
                    {
                      "type": "Theorem",
                      "label": "source.root.theorem.proof.root.reverse.convergence_condition.witness_verification",
