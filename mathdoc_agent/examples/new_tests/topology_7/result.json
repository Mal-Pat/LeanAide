                "label": "source.root.theorem.proof.root.reverse.arbitrary_neighborhood",
                "header": "Claim",
                "claim": "U \\subseteq X \\land U \\text{ is open in } X \\land L \\in U.",
                "proof": {
                  "type": "Proof",
                  "proof_steps": [
                    {
