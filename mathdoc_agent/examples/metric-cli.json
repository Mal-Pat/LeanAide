{
  "document": {
    "type": "document",
    "body": [
      {
        "type": "Theorem",
        "label": "metric.root.theorem",
        "header": "Theorem",
        "claim": "Let $(X, d)$ be a metric space. Let $x$ and $y$ be two distinct points with distance $d(x, y) = \\epsilon > 0$. Then the open balls $B(x, \\epsilon/3)$ and $B(y, \\epsilon/3)$ do not intersect.",
        "proof": {
          "type": "contradiction_statement",
          "assumption": "\\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\ne\\varnothing\\), equivalently there exists \\(z\\in X\\) lying in both balls.",
          "proof": {
            "type": "Proof",
            "proof_steps": [
              {
                "type": "contradiction_statement",
                "assumption": "\\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\ne\\varnothing\\)",
                "proof": {
                  "type": "Proof",
                  "proof_steps": [
                    {
                      "type": "assert_statement",
                      "claim": "Negate the desired disjointness conclusion.",
                      "id": "metric.root.theorem.proof.root.assumption.negated_assumption",
                      "status": "classified",
                      "text": "Assume for contradiction that \\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\ne\\varnothing\\)."
                    },
                    {
                      "type": "Proof",
                      "claim_label": "Produce a witness in the intersection.",
                      "proof_steps": [
                        {
                          "type": "Proof",
                          "claim_label": "Produce a witness in the intersection.",
                          "proof_steps": [
                            {
                              "type": "assert_statement",
                              "claim": "Produce a witness in the intersection."
                            }
                          ],
                          "id": "metric.root.theorem.proof.root.assumption.intersection_witness.witness_selection.witness_choice",
                          "status": "classified"
                        },
                        {
                          "type": "assert_statement",
                          "claim": "\\(z\\in B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\)",
                          "proof_method": "This is exactly the stated hypothesis for the chosen witness \\(z\\)."
                        }
                      ],
                      "id": "metric.root.theorem.proof.root.assumption.intersection_witness.witness_selection",
                      "status": "decomposed"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "Because \\(z\\in B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\), we have \\(z\\in B(x,\\varepsilon/3)\\) and \\(z\\in B(y,\\varepsilon/3)\\).",
                      "id": "metric.root.theorem.proof.root.assumption.intersection_witness.witness_properties",
                      "status": "classified",
                      "text": "Because \\(z\\in B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\), we have \\(z\\in B(x,\\varepsilon/3)\\) and \\(z\\in B(y,\\varepsilon/3)\\)."
                    },
                    {
                      "type": "assert_statement",
                      "claim": "By the definition of open balls, \\(d(z,x)<\\varepsilon/3\\) and \\(d(z,y)<\\varepsilon/3\\).",
                      "id": "metric.root.theorem.proof.root.assumption.open_ball_consequences",
                      "status": "classified",
                      "text": "By the definition of open balls, \\(d(z,x)<\\varepsilon/3\\) and \\(d(z,y)<\\varepsilon/3\\)."
                    }
                  ]
                },
                "id": "metric.root.theorem.proof.root.assumption",
                "status": "decomposed"
              },
              {
                "type": "triangle_inequality_estimate",
                "start": "d(x,y)",
                "target": "2\\varepsilon/3",
                "goal_relation": "mixed",
                "steps": [
                  {
                    "from": "d(x,y)",
                    "relation": "<=",
                    "to": "d(x,z)+d(z,y)",
                    "justification": "triangle inequality"
                  },
                  {
                    "from": "d(x,z)+d(z,y)",
                    "relation": "<",
                    "to": "\\varepsilon/3+\\varepsilon/3",
                    "justification": "using d(x,z)=d(z,x), d(z,x)<\\varepsilon/3, and d(z,y)<\\varepsilon/3",
                    "side_conditions": [
                      "symmetry of the metric gives d(x,z)=d(z,x)"
                    ]
                  },
                  {
                    "from": "\\varepsilon/3+\\varepsilon/3",
                    "relation": "=",
                    "to": "2\\varepsilon/3",
                    "justification": "arithmetic simplification"
                  }
                ],
                "id": "metric.root.theorem.proof.root.triangle-bound",
                "status": "resolved",
                "text": "By the triangle inequality, \\(d(x,y)\\le d(x,z)+d(z,y)\\). Since \\(d(x,z)=d(z,x)<\\varepsilon/3\\) and \\(d(z,y)<\\varepsilon/3\\), it follows that \\(d(x,y)<2\\varepsilon/3\\)."
              },
              {
                "type": "contradiction_statement",
                "assumption": "\\(d(x,y)=\\varepsilon\\)",
                "proof": {
                  "type": "Proof",
                  "proof_steps": [
                    {
                      "type": "rewrite_by_hypothesis",
                      "start": "\\varepsilon",
                      "target": "2\\varepsilon/3",
                      "goal_relation": "mixed",
                      "steps": [
                        {
                          "from": "\\varepsilon",
                          "relation": "=",
                          "to": "d(x,y)",
                          "justification": "from the hypothesis \\(d(x,y)=\\varepsilon\\), by symmetry of equality"
                        },
                        {
                          "from": "d(x,y)",
                          "relation": "<",
                          "to": "2\\varepsilon/3",
                          "justification": "given hypothesis"
                        }
                      ],
                      "id": "metric.root.theorem.proof.root.contradiction.ineq-substitution",
                      "status": "resolved",
                      "text": "From \\(d(x,y)=\\varepsilon\\) and \\(d(x,y)<2\\varepsilon/3\\), infer \\(\\varepsilon<2\\varepsilon/3\\)."
                    },
                    {
                      "type": "calculation_to_contradiction",
                      "start": "\\varepsilon",
                      "target": "2/3",
                      "goal_relation": "<",
                      "steps": [
                        {
                          "from": "\\varepsilon",
                          "relation": "<",
                          "to": "2\\varepsilon/3",
                          "justification": "hypothesis"
                        },
                        {
                          "from": "\\varepsilon/\\varepsilon",
                          "relation": "<",
                          "to": "(2\\varepsilon/3)/\\varepsilon",
                          "justification": "divide both sides by the positive quantity \\(\\varepsilon\\)",
                          "side_conditions": [
                            "\\varepsilon>0"
                          ]
                        },
                        {
                          "from": "1",
                          "relation": "<",
                          "to": "2/3",
                          "justification": "simplify",
                          "side_conditions": [
                            "\\varepsilon>0"
                          ]
                        }
                      ],
                      "id": "metric.root.theorem.proof.root.contradiction.positive-division",
                      "status": "resolved",
                      "text": "Because \\(\\varepsilon>0\\), divide \\(\\varepsilon<2\\varepsilon/3\\) by \\(\\varepsilon\\) to get \\(1<2/3\\)."
                    },
                    {
                      "type": "contradiction_statement",
                      "proof": {
                        "type": "Proof",
                        "proof_steps": []
                      },
                      "id": "metric.root.theorem.proof.root.contradiction.contradiction",
                      "status": "classified"
                    }
                  ]
                },
                "id": "metric.root.theorem.proof.root.contradiction",
                "status": "decomposed"
              },
              {
                "type": "Proof",
                "claim_label": "Conclude the desired disjointness statement.",
                "proof_steps": [
                  {
                    "type": "assert_statement",
                    "claim": "The assumption that the two balls intersect is false.",
                    "proof_method": "Since assuming nonempty intersection leads to a contradiction."
                  },
                  {
                    "type": "assert_statement",
                    "claim": "\\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)=\\varnothing\\).",
                    "proof_method": "This is the negation of the false assumption that the two balls intersect."
                  }
                ],
                "id": "metric.root.theorem.proof.root.conclusion",
                "status": "resolved",
                "text": "Therefore the assumption that the two balls intersect is false. Hence \\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)=\\varnothing\\)."
              }
            ]
          },
          "id": "metric.root.theorem.proof.root",
          "status": "decomposed"
        },
        "id": "metric.root.theorem",
        "status": "decomposed"
      }
    ]
  }
}
